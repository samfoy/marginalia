# marginalia — environment configuration
# Copy this file to .env, fill in your values, then: set -a && source .env && set +a
# (set -a auto-exports every variable so child processes can see them)
# Or pass individual vars when running: MARGINALIA_VAULT=~/Vault marginalia serve

# ── Required: choose ONE provider ─────────────────────────────────────────────

## Option A: OpenAI  (recommended — simplest setup, widest model choice)
# export MARGINALIA_OPENAI_API_KEY=sk-...
# export MARGINALIA_MODEL_ID=openai:gpt-4o

## Option B: Anthropic
# export MARGINALIA_ANTHROPIC_API_KEY=sk-ant-...
# export MARGINALIA_MODEL_ID=anthropic:claude-opus-4-5

## Option C: AWS Bedrock
# export MARGINALIA_AWS_PROFILE=your-aws-profile
# export MARGINALIA_AWS_REGION=us-west-2
# export MARGINALIA_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ── Required: Obsidian vault ───────────────────────────────────────────────────
# export MARGINALIA_VAULT=~/Documents/YourVault

# Subdirectory inside the vault where book notes are saved (relative path or absolute).
# export MARGINALIA_BOOKS_DIR=~/Documents/YourVault/Notes/Books

# ── Optional: AI model settings ───────────────────────────────────────────────

# Explicit fallback chain (comma-separated). Auto-derived from primary if unset.
# export MARGINALIA_MODEL_CHAIN=openai:gpt-4o,openai:gpt-4o-mini,anthropic:claude-haiku-3-5

# Terminal fallback when no auto-derived fallbacks apply (AWS Bedrock users).
# export MARGINALIA_FALLBACK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Max tokens for companion responses (recap, wiki, chat, ask).
# export MARGINALIA_MAX_TOKENS=600

# Reasoning effort for companion calls (OpenAI/Bedrock only; no-op for Anthropic direct). Lower = faster/cheaper.
# export MARGINALIA_COMPANION_EFFORT=low   # none | low | medium | high

# Circuit breaker: seconds a failed model is skipped before re-probing.
# export MARGINALIA_MODEL_COOLDOWN_S=120

# ── Optional: Calibre library ─────────────────────────────────────────────────
# Path to your Calibre library directory (contains metadata.db).
# Auto-detected at ~/Calibre Library on macOS.
# export MARGINALIA_CALIBRE_DB="~/Calibre Library"

# ── Optional: bridge settings ─────────────────────────────────────────────────
# export MARGINALIA_PORT=7731

# Shared secret — set the same value in the KOReader plugin settings.
# Leave empty for no auth (safe on a home network).
# export MARGINALIA_TOKEN=

# ── Optional: embeddings (RAG) ────────────────────────────────────────────────
# Which embedding backend to use. "auto" picks the best available.
# export MARGINALIA_EMBED_BACKEND=auto   # auto | local | openai | bedrock

# sentence-transformers model for local embeddings. ~80MB, no GPU required.
# export MARGINALIA_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2

# Embedding model for OpenAI or Bedrock Cohere backend.
# Override the embedding model for your chosen backend:
# export MARGINALIA_EMBED_MODEL=text-embedding-3-small   # if EMBED_BACKEND=openai
# export MARGINALIA_EMBED_MODEL=cohere.embed-english-v3  # if EMBED_BACKEND=bedrock

# ── Optional: Book Index generation ──────────────────────────────────────────
# Max tokens the LLM can use when generating the Book Index.
# export MARGINALIA_XRAY_MAX_TOKENS=16384

# Model used specifically for chunked large-book processing (defaults to MARGINALIA_MODEL_ID).
# Useful if you want a cheaper model for the chunking pass.
# export MARGINALIA_CHUNK_MODEL_ID=openai:gpt-4o-mini

# Concurrent EPUB chunk processing for very large books.
# export MARGINALIA_MAX_PARALLEL_CHUNKS=4
